{
    "name": "artwallet/vaultrbac",
    "description": "Enterprise-grade, tenant-aware RBAC for Laravel (VaultRBAC).",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "rbac",
        "permissions",
        "roles",
        "authorization",
        "multi-tenant"
    ],
    "require": {
        "php": "^8.2",
        "illuminate/cache": "^11.0|^12.0|^13.0",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/auth": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/log": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0|^11.0",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Artwallet\\VaultRbac\\": "src/",
            "Artwallet\\VaultRbac\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Artwallet\\VaultRbac\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Artwallet\\VaultRbac\\VaultRbacServiceProvider"
            ],
            "aliases": {
                "VaultRbac": "Artwallet\\VaultRbac\\Facades\\VaultRbac"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "@php vendor/bin/phpunit -c phpunit.xml.dist",
        "test:unit": "@php vendor/bin/phpunit -c phpunit.xml.dist --testsuite Unit",
        "test:integration": "@php vendor/bin/phpunit -c phpunit.xml.dist --testsuite Integration",
        "test:security": "@php vendor/bin/phpunit -c phpunit.xml.dist --group security",
        "test:diagnostics": "@php vendor/bin/phpunit -c phpunit.xml.dist --testsuite Diagnostics"
    }
}
