APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12
HASH_DRIVER=argon2id

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# SQLite (default for local dev). For production VPS use MySQL:
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=art_wallet
# DB_USERNAME=art_wallet
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
# Set true only while `npm run dev` is running. When false, built CSS/JS from public/build are used (ignores stale public/hot).
VITE_USE_HOT=false

# Frontend: run `npm ci` && `npm run build` after clone (or `npm run dev` with VITE_USE_HOT=true).

# ArtGate (artixcore/artgate) — optional; defaults live in vendor config. Former VaultRBAC env names map as follows:
# VAULTRBAC_* → ARTGATE_* (e.g. ARTGATE_DEFAULT_TENANT_ID, ARTGATE_GATE_ABILITY, ARTGATE_CACHE_PREFIX, ARTGATE_FRESHNESS_HEADER).
# See vendor/artixcore/artgate/config/artgate.php after `composer install` for the full list.
#
# RBAC_DRIVER: artgate (default) | legacy (same as artgate here) | compare (staging: log full-stack vs raw DB mismatches).
RBAC_DRIVER=artgate
# Load RBAC tables from the package until you publish migrations into database/migrations:
ARTGATE_RUN_PACKAGE_MIGRATIONS=true

# Seeded administrator (php artisan db:seed). Change password after first login in production.
ADMIN_NAME="Administrator"
ADMIN_EMAIL=admin@art-wallet.test
ADMIN_PASSWORD=ChangeMe!Admin2026

# Observability (scheduled probes in routes/console.php). TTLs drive "stale" in operator dashboard and /ops/monitor/health.
# OBSERVABILITY_TTL_DEFAULT=120
# OBSERVABILITY_TTL_QUEUE=180
# OBSERVABILITY_TTL_DATABASE=60
# OBSERVABILITY_TTL_RPC=300
# OBSERVABILITY_TTL_NOTIFICATIONS=300
# OBSERVABILITY_PROBE_VERSION=1

# External monitoring: GET /ops/monitor/health returns 404 when unset (see docs/ops/deploy.md).
# OPS_MONITOR_TOKEN=
# OPS_MONITOR_FAIL_ON_STALE=true
# OPS_MONITOR_FAIL_ON_CRITICAL=true
# OPS_MONITOR_FAIL_ON_PARTIAL=false

# ArtWallet security (backup / trusted devices / challenges). Optional pepper for session-binding HMAC; empty uses APP_KEY.
# ARTWALLET_SESSION_PEPPER=
# ARTWALLET_CHALLENGE_TTL=600

# Chain RPC / indexing (self-hosted VPS). Defaults hit public endpoints (rate-limited).
# ARTWALLET_ETH_RPC_URL=https://cloudflare-eth.com
# ARTWALLET_SOL_RPC_URL=https://api.mainnet-beta.solana.com
# ARTWALLET_BTC_ESPLORA_URL=https://blockstream.info/api
# ARTWALLET_TRON_API_URL=https://api.trongrid.io
# ARTWALLET_INTENT_TTL_MINUTES=15
# ARTWALLET_SIGNING_REQUEST_TTL_MINUTES=10
# ARTWALLET_FEE_ESTIMATE_TTL_SECONDS=60

# API v1 (Sanctum bearer + device header X-ArtWallet-Device-Id). Routes: /api/v1/*
# ARTWALLET_API_ACCESS_TTL=45
# ARTWALLET_API_REFRESH_TTL_DAYS=30

# Realtime (Laravel Reverb + Echo). Use BROADCAST_CONNECTION=reverb in production; `php artisan reverb:start`
# BROADCAST_CONNECTION=log
# REVERB_APP_ID=
# REVERB_APP_KEY=
# REVERB_APP_SECRET=
# REVERB_HOST=localhost
# REVERB_PORT=8080
# REVERB_SCHEME=http

# Sanctum SPA domains (comma-separated) if first-party SPA shares cookies with API
# SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1
